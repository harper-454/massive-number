generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projects  Project[]
  chats     Chat[]
  settings  UserSettings?
}

model UserSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  theme             String   @default("dark")
  accentColor       String   @default("emerald")
  fontFamily        String   @default("geist")
  fontSize          Int      @default(14)
  tabSize           Int      @default(2)
  wordWrap          Boolean  @default(true)
  lineNumbers       Boolean  @default(true)
  minimap           Boolean  @default(true)
  defaultModel      String   @default("auto")
  activePersona     String   @default("default")
  agentAutoApprove  Boolean  @default(false)
  voiceEnabled      Boolean  @default(false)
  costOptimization  Boolean  @default(true)
  webGrounding      Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  path        String?
  language    String?
  framework   String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chats       Chat[]
  files       File[]
  agents      AgentRun[]
}

model Chat {
  id        String      @id @default(cuid())
  title     String      @default("New Chat")
  projectId String?
  userId    String
  model     String      @default("auto")
  mode      String      @default("chat")
  persona   String      @default("default")
  folderId  String?
  pinned    Boolean     @default(false)
  archived  Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  folder    ChatFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  messages  Message[]
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  role      String
  content   String
  model     String?
  tokens    Int      @default(0)
  cost      Float    @default(0)
  toolCalls String?
  sources   String?
  duration  Int      @default(0)
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

model File {
  id        String   @id @default(cuid())
  projectId String
  name      String
  path      String
  content   String   @default("")
  language  String?
  isDir     Boolean  @default(false)
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AgentRun {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  status      String   @default("pending")
  steps       String   @default("[]")
  result      String?
  model       String   @default("auto")
  tokens      Int      @default(0)
  cost        Float    @default(0)
  duration    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProviderConfig {
  id        String   @id @default(cuid())
  name      String   @unique
  provider  String
  apiKey    String
  baseUrl   String?
  models    String   @default("[]")
  enabled   Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ToolConfig {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("mcp")
  command     String?
  args        String?
  enabled     Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// MCP Server connections - real connections managed by user
model McpServer {
  id          String   @id @default(cuid())
  serverId    String   @unique
  name        String
  description String?
  category    String
  icon        String?
  tools       String   @default("[]")
  config      String   @default("{}")
  connected   Boolean  @default(false)
  health      String   @default("unknown")
  lastConnectedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Specs - spec-to-code pipeline
model Spec {
  id                  String   @id @default(cuid())
  title               String
  description         String
  requirements        String   @default("[]")
  designNotes         String?
  implementationSteps String   @default("[]")
  testCriteria        String   @default("[]")
  complexity          String   @default("medium")
  affectedFiles       String   @default("[]")
  status              String   @default("draft")
  model               String   @default("auto")
  projectId           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// Marketplace items - installed integrations
model InstalledIntegration {
  id          String   @id @default(cuid())
  itemId      String   @unique
  name        String
  description String?
  category    String?
  author      String?
  version     String   @default("1.0.0")
  rating      Float    @default(0)
  downloads   Int      @default(0)
  price       String   @default("free")
  verified    Boolean  @default(false)
  config      String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Notifications - real user notifications
model Notification {
  id          String   @id @default(cuid())
  type        String   @default("info")
  title       String
  description String?
  read        Boolean  @default(false)
  actionUrl   String?
  createdAt   DateTime @default(now())
}

// Activity log - real user activity
model Activity {
  id          String   @id @default(cuid())
  action      String
  entity      String?
  entityId    String?
  description String?
  metadata    String   @default("{}")
  createdAt   DateTime @default(now())
}

// Memory entries - persistent AI context
model Memory {
  id          String   @id @default(cuid())
  category    String   @default("preference")
  content     String
  source      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Codebase context - indexed files for AI
model CodebaseContext {
  id            String   @id @default(cuid())
  filePath      String
  language      String?
  relevance     Float    @default(0)
  lastIndexedAt DateTime @default(now())
}

// Project knowledge - key-value store
model Knowledge {
  id        String   @id @default(cuid())
  topic     String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// AI Personas - custom AI behaviors
model Persona {
  id          String   @id @default(cuid())
  name        String
  icon        String   @default("🤖")
  description String?
  systemPrompt String
  focus       String?
  isPreset    Boolean  @default(false)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// AI Rules - behavioral rules for AI
model AiRule {
  id          String   @id @default(cuid())
  name        String
  content     String
  enabled     Boolean  @default(true)
  isPreset    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Snippets - user code snippets
model Snippet {
  id          String   @id @default(cuid())
  name        String
  language    String
  description String?
  code        String
  favorite    Boolean  @default(false)
  isPreset    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Collaborators - real session participants
model Collaborator {
  id          String   @id @default(cuid())
  name        String
  email       String?
  avatar      String?
  status      String   @default("offline")
  cursorFile  String?
  cursorLine  Int?
  color       String   @default("#10b981")
  sessionId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Account Management ──────────────────────────────────────────────────

model Account {
  id            String   @id @default(cuid())
  userId        String   @unique
  displayName   String?
  email         String   @unique
  avatarUrl     String?
  bio           String?
  role          String   @default("user")
  plan          String   @default("free")
  status        String   @default("active")
  lastLoginAt   DateTime?
  loginCount    Int      @default(0)
  preferences   String   @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ── Chat History ─────────────────────────────────────────────────────────

model ChatFolder {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#10b981")
  icon      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chats     Chat[]
}

// ── Library - Generated Sites, Apps, Objects, Assets ─────────────────────

model LibraryItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // site, app, component, asset, api, game, model, template
  category    String   // web, mobile, backend, fullstack, game, modeling, design
  tags        String   @default("[]")
  thumbnail   String?
  code        String   @default("")
  config      String   @default("{}")
  status      String   @default("draft") // draft, published, archived
  version     String   @default("1.0.0")
  isPublic    Boolean  @default(false)
  stars       Int      @default(0)
  forks       Int      @default(0)
  parentId    String?  // for forked items
  userId      String   @default("default")
  projectId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Subscription & Billing ──────────────────────────────────────────────

model Subscription {
  id                String    @id @default(cuid())
  userId            String    @unique
  plan              String    @default("free")  // free, pro, enterprise
  status            String    @default("active")  // active, past_due, canceled, trialing
  stripeCustomerId  String?   @unique
  stripePriceId     String?
  stripeSubId       String?   @unique
  currentPeriodStart DateTime?
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model TokenUsage {
  id           String   @id @default(cuid())
  userId       String
  model        String
  provider     String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  cost         Float    @default(0)
  period       String   // "2024-01" format for monthly
  createdAt    DateTime @default(now())
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  provider   String    // openai, anthropic, google, deepseek, custom, lmstudio, ollama
  label      String?
  key        String    // encrypted or reference
  baseUrl    String?   // for custom/local providers
  models     String    @default("[]")
  enabled    Boolean   @default(true)
  isLocal    Boolean   @default(false)  // true for LM Studio/Ollama
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Donation {
  id              String   @id @default(cuid())
  userId          String?
  amount          Float
  currency        String   @default("usd")
  message         String?
  stripeSessionId String?
  createdAt       DateTime @default(now())
}

// ── Dev Surfaces - Specialized workspaces ────────────────────────────────

model DevSurface {
  id          String   @id @default(cuid())
  name        String
  type        String   // modeling, game, web-design, backend, frontend, fullstack, mobile, data, api, devops
  description String?
  icon        String?
  color       String   @default("#10b981")
  tools       String   @default("[]")
  layout      String   @default("{}")
  status      String   @default("active")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Project Templates ────────────────────────────────────────────────────

model ProjectTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String   // starter, fullstack, frontend, backend, game, mobile, api
  framework   String?
  language    String?
  thumbnail   String?
  files       String   @default("[]")
  config      String   @default("{}")
  isOfficial  Boolean  @default(false)
  stars       Int      @default(0)
  downloads   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
